# ════════════════════════════════════════════════════════════════════
# Repo-root .env.example — copy to .env and fill in the secrets.
# .env is gitignored; this file is its committed, secret-free twin —
# keep the two structurally in sync when adding a variable.
#
# The .env is read by BOTH Python components:
#   agent/             (analytics agent, docker-compose service)
#   collection-agent/  (live-collection CLI + phone scan server)
#
# Convention: variables the code REQUIRES (secrets, identity) are
# active. Optional knobs are listed COMMENTED-OUT with their code
# default shown — uncomment only to override. Don't copy defaults in
# as active values: a stale copy silently overrides future default
# changes in code.
# ════════════════════════════════════════════════════════════════════


# ─── Shared: OpenAI ──────────────────────────────────────────────────
# Required by agent/ (LLM_BACKEND=openai) and by collection-agent for
# chat + photo-scan vision calls.
OPENAI_API_KEY=


# ─── Shared: LangSmith tracing (optional) ────────────────────────────
# Flag/key/endpoint are read by BOTH components (021). Absent/false ⇒
# tracing is a strict no-op. Each component traces into its OWN project
# (two vars below) so runs never interleave.
# LANGSMITH_TRACING=false
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# Project for agent/ traces.
# LANGSMITH_PROJECT=discogs_agent
# Project for collection-agent traces (deliberately a dedicated var —
# inheriting LANGSMITH_PROJECT would mix both components' traces).
# COLLECTION_AGENT_LANGSMITH_PROJECT=discogs-collection-agent


# ════════════════════════════════════════════════════════════════════
# agent/ — analytics agent over the published DuckDB (004..016)
# ════════════════════════════════════════════════════════════════════

# Model tiers: cheap for routing/understanding, strong for code-gen.
# Defaults: gpt-4o-mini / gpt-4o
# CHEAP_MODEL=gpt-4o-mini
# STRONG_MODEL=gpt-4o

# Where the agent reads the published DuckDB. Container path (compose
# bind-mounts ./data); adjust only for non-compose runs.
# Default: /app/data/published/duckdb/discogs.duckdb
# ANALYTICS_DUCKDB_PATH=/app/data/published/duckdb/discogs.duckdb

# Postgres persistence (compose sets this for the container; keep in sync).
# Default: postgresql+psycopg://agent:agent@postgres:5432/agent
# DATABASE_URL=postgresql+psycopg://agent:agent@postgres:5432/agent

# Where chart artifacts land. Bind-mounted from ./artifacts at the host.
# Default: /app/artifacts
# ARTIFACTS_DIR=/app/artifacts

# Retry budget across safety + validation paths. Default: 3
# (bumped from 2 on 2026-05-11 — see agent/src/discogs_agent/config.py)
# MAX_RETRIES=3

# Hard wall-clock cap for the sandbox subprocess (seconds). Default: 30
# SANDBOX_TIMEOUT_SECONDS=30

# Multi-turn carry-over (US4): bounded by both turns and tokens.
# Defaults: 4 turns / 512 tokens
# THREAD_CARRYOVER_TURNS=4
# THREAD_CARRYOVER_TOKEN_BUDGET=512

# LLM backend selector: "openai" (real) or "stub" (in-process; tests
# only). Default: openai
# LLM_BACKEND=openai

# Logging level for the agent service. Default: INFO
# LOG_LEVEL=INFO

# Admin auth for /runs/{id} debug fields and /threads/{id} admin views.
# Empty disables admin mode entirely (default for safety).
AGENT_ADMIN_TOKEN=

# Comma-separated origins allowed to call the agent API from a browser
# (008 frontend). Default: the Vite dev-server origins.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Build version surfaced by /health; normally injected by Docker build
# args — set here only for local debugging. Default: dev
# AGENT_VERSION=dev


# ════════════════════════════════════════════════════════════════════
# collection-agent/ — live Discogs collection CLI + scan server (017+)
# ════════════════════════════════════════════════════════════════════

# ─── Discogs identity (REQUIRED) ─────────────────────────────────────
# Personal access token (Discogs → Settings → Developers). The code
# accepts DISCOGS_USER_TOKEN or DISCOGS_TOKEN. Secret: never logged,
# never persisted to the snapshot.
DISCOGS_TOKEN=
# Account username (optional — discovered live via /oauth/identity when
# absent; setting it skips that lookup).
DISCOGS_USERNAME=
# Unique User-Agent required by Discogs API terms, e.g.
# "collection-agent/1.0 (your-username)". Also readable as
# COLLECTION_AGENT_USER_AGENT.
DISCOGS_USER_AGENT=

# ─── Discogs endpoints ───────────────────────────────────────────────
# REST API base. Default: https://api.discogs.com
# DISCOGS_BASE_URL=https://api.discogs.com
# Human-facing website base — release/master page links (019/026) are
# built from it. Default: https://www.discogs.com
# DISCOGS_WEB_BASE_URL=https://www.discogs.com

# ─── Models ──────────────────────────────────────────────────────────
# Chat-loop model for the conversational agent. Default: gpt-4o-mini
# COLLECTION_AGENT_MODEL=gpt-4o-mini
# Vision-capable model for photo evidence extraction (022) — a separate
# knob so chat and vision can be repointed independently.
# Default: gpt-4o-mini
# COLLECTION_AGENT_VISION_MODEL=gpt-4o-mini

# ─── Snapshot ────────────────────────────────────────────────────────
# Local collection snapshot produced by sync; served at chat speed.
# Default: collection-agent/data/snapshot.json
# SNAPSHOT_PATH=collection-agent/data/snapshot.json

# ─── Phone record scan (022/024/025/026) ─────────────────────────────
# Bind address/port of the LAN scan server. Defaults: 0.0.0.0 / 8022
# COLLECTION_AGENT_SCAN_HOST=0.0.0.0
# COLLECTION_AGENT_SCAN_PORT=8022
# Target collection folder for adds (1 = Uncategorized); validated live
# at server startup. Default: 1
# COLLECTION_AGENT_SCAN_FOLDER_ID=1
# Candidate list cap per scan/search. Default: 8
# COLLECTION_AGENT_SCAN_CANDIDATES_MAX=8
# Photo upload cap in bytes. Default: 10485760 (10 MiB)
# COLLECTION_AGENT_SCAN_MAX_IMAGE_BYTES=10485760
# Hard cap per vision call, seconds — a hung provider call must not run
# unbounded after a re-scan (022 addendum 2). Default: 45
# COLLECTION_AGENT_SCAN_VISION_TIMEOUT_S=45
# Append-only per-session scan journal location.
# Default: collection-agent/data/scan-sessions
# COLLECTION_AGENT_SCAN_JOURNAL_DIR=collection-agent/data/scan-sessions
# Catno-rung fetch depth for the exact-catno re-rank (024 — short
# catnos drown under Discogs' substring search). Default: 50
# COLLECTION_AGENT_SCAN_CATNO_SEARCH_DEPTH=50
# Cap of the on-demand "other pressings of this master" list (026).
# Default: 25
# COLLECTION_AGENT_SCAN_VERSIONS_MAX=25

# ─── Scan identification eval (023) ──────────────────────────────────
# Opt-in retention of uploaded scan photos for the eval dataset.
# Default: false (OFF ⇒ scan behavior byte-identical to 022)
# COLLECTION_AGENT_SCAN_RETAIN_PHOTOS=false
# Where retained photos land.
# Default: collection-agent/data/eval/scan-photos
# COLLECTION_AGENT_SCAN_RETENTION_DIR=collection-agent/data/eval/scan-photos
# Downloaded Discogs-image dataset location (uploader-copyrighted:
# local-only, gitignored). Default: collection-agent/data/eval/discogs-images
# COLLECTION_AGENT_EVAL_DATASET_DIR=collection-agent/data/eval/discogs-images
# Images fetched per release (secondary images preferred). Default: 2
# COLLECTION_AGENT_EVAL_IMAGES_PER_RELEASE=2
# Eval run output (results.jsonl + summary.json per run).
# Default: collection-agent/data/eval/runs
# COLLECTION_AGENT_EVAL_RESULTS_DIR=collection-agent/data/eval/runs

# ─── YouTube play links (020) ────────────────────────────────────────
# Site base for tool-built watch_videos links (the agent never calls
# YouTube — it only emits URLs). Default: https://www.youtube.com
# YOUTUBE_WEB_BASE_URL=https://www.youtube.com
# Max video ids per play link; longer requests are chunked. Default: 50
# YOUTUBE_PLAYLIST_MAX_IDS=50

# ─── Rate limiting ───────────────────────────────────────────────────
# Remaining-requests floor before the client sleeps a window (Discogs
# allows 60 req/min authenticated). Default: 2
# RATE_LIMIT_FLOOR=2

# ─── Rarity thresholds (017 R9; surfaced in every rarity answer) ─────
# "Rare" = few for sale, wanted more than had, enough haves to matter.
# Defaults: 2 / 2.0 / 10
# RARITY_MAX_FOR_SALE=2
# RARITY_WANT_HAVE_RATIO=2.0
# RARITY_MIN_HAVE=10

# ─── Answer shaping ──────────────────────────────────────────────────
# Row cap for filter/listing tool results. Default: 50
# FILTER_RESULT_LIMIT=50
# Listing titles longer than this are ellipsis-truncated for display
# (matching unaffected, 020 delta 11). Default: 70
# LISTING_TITLE_MAX_CHARS=70
